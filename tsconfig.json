{
	"compilerOptions": {
		"target": "esnext",
		"module": "esnext",
		"moduleResolution": "bundler",
		"strict": true,
		"types": ["vitest/globals", "node"],
		"paths": {
			"@remux": ["./remux/build"],
			"@server": ["./src"],
			"@www": ["./www"]
		}
