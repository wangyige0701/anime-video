{
	"compilerOptions": {
		"target": "esnext",
		"module": "esnext",
		"moduleResolution": "bundler",
		"strict": true,
		"types": ["vitest/globals", "node"],
		"paths": {
			"@remux": ["./remux/build"],
			"@server": ["./server/*"],
			"@www": ["./www/*"]
		}
	},
	"include": ["server", "test", "dev"],
	"exclude": ["node_modules"]
}
