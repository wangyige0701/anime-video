{
	"compilerOptions": {
		"target": "esnext",
		"module": "esnext",
		"moduleResolution": "bundler",
		"strict": true,
		"outDir": "./dist",
		"experimentalDecorators": true,
		"emitDecoratorMetadata": true,
		"types": ["vitest/globals", "node"],
		"paths": {
			"@remux/*": ["./remux/build/*"],
			"@hls/*": ["./hls/build/*"],
			"@server/*": ["./server/*"],
			"@www/*": ["./www/*"]
		}
	},
	"include": ["server", "test", "dev"],
	"exclude": ["node_modules"]
}
