{
	"compilerOptions": {
		"target": "esnext",
		"module": "esnext",
		"moduleResolution": "bundler",
		"strict": true,
		"outDir": "./dist",
		"experimentalDecorators": true,
		"emitDecoratorMetadata": true,
		"types": ["vitest/globals", "node"],
		"paths": {
			"@remux/*": ["./remux/build/*"],
			"@hls/*": ["./hls/build/*"],
			"@server/*": ["./server/*"],
			"@web/*": ["./web/*"],
			"@config/*": ["./config/*"],
			"~routes/*": ["./routes/*"],
			"~types/*": ["./types/*"]
		}
	},
	"include": ["server", "test", "dev", "test", "web", "config", "types", "routes"],
	"exclude": ["node_modules"]
}
